# Postgres (Neon): run `npm run db:migrate` after setting this locally
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

OPENAI_API_KEY=""
UNSPLASH_ACCESS_KEY=""
BLOB_READ_WRITE_TOKEN=""

RESEND_API_KEY=""
EMAIL_FROM="Daily Motivation <hello@yourdomain.com>"
RESEND_WEBHOOK_SECRET=""

APP_URL="http://localhost:3000"
# Which calendar day is “today” for content + sends
APP_TIMEZONE="America/New_York"

# Vercel calls /api/cron/daily with Authorization: Bearer …
CRON_SECRET=""

# Hobby: Vercel cron runs at most once/day (UTC). Edit vercel.json — default
# 14:00 UTC ≈ 09:00 America/New_York in winter (EST). Summer (EDT) use 13:00 UTC.

# Manual “today only” content (no emails): with dev server running,
# curl -sS -H "Authorization: Bearer $CRON_SECRET" http://localhost:3000/api/tools/generate-today
